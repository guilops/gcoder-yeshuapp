<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - VUC Locadora</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400&display=swap" rel="stylesheet">
    <style>
        body {
            background-color: #23272b; /* Cinza escuro */
            color: #f5f5f5; /* Texto claro */
            font-family: 'Cinzel', Arial, sans-serif;
            margin: 0;
            padding: 20px;
        }

        .navbar {
            background-color: #23272b !important; /* Cinza escuro */
            border-bottom: 2px solid #ff9800; /* Laranja */
        }

        .navbar-brand img {
            filter: brightness(0.95);
        }

        .navbar-nav .nav-link {
            color: #f5f5f5 !important;
            transition: color 0.2s;
        }

            .navbar-nav .nav-link.active,
            .navbar-nav .nav-link:focus,
            .navbar-nav .nav-link:hover {
                color: #ff9800 !important; /* Laranja */
            }

        .btn-success, .btn-primary {
            background-color: #ff9800;
            border-color: #ff9800;
            color: #23272b;
        }

            .btn-success:hover, .btn-primary:hover {
                background-color: #ffa733;
                border-color: #ffa733;
                color: #23272b;
            }

        .table-dark {
            background-color: #2c3035;
            color: #f5f5f5;
        }

            .table-dark th, .table-dark td {
                border-color: #444950;
            }

        .table-striped > tbody > tr:nth-of-type(odd) {
            background-color: #23272b;
        }

        .alert-danger {
            background-color: #3a2323;
            color: #ff9800;
            border-color: #ff9800;
        }

        footer.footer {
            background-color: #23272b;
            color: #bdbdbd;
            padding: 0.2rem 0;
            font-size: 0.8rem;
            border-top: 2px solid #ff9800;
        }

        /* Links padrão */
        a, a:visited {
            color: #ff9800;
            text-decoration: none;
        }

            a:hover, a:focus {
                color: #ffa733;
                text-decoration: underline;
            }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark border-bottom box-shadow mb-3">
            <div class="container-fluid px-3">
                <a class="navbar-brand" asp-area="" asp-page="/Home">
                    <img src="~/logo3.png" style="max-width: 100px; height: auto;" alt="Logo" />
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/Caminhao/Index">Minha Frota</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/Logout">Sair</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container-fluid px-3">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>
    <footer class="border-top footer text-muted mt-auto py-3">
        <div class="container-fluid px-3">
            &copy; @DateTime.Now.Year - Todos os direitos reservados - GLCoder 2026
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>