<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>VUC Locadora</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600&display=swap" rel="stylesheet">
    <style>
        body {
            background-color: #23272b;
            font-family: 'Inter', 'Segoe UI', Arial, sans-serif;
            margin: 0;
            padding: 0;
            font-size: 16px;
            color: #f5f5f5;
        }

        header {
            background-color: #23272b;
        }

        .navbar {
            background-color: #23272b;
            box-shadow: 0 4px 6px rgba(255, 152, 0, 0.08);
        }

        .navbar-brand img {
            max-width: 50px;
            height: auto;
            filter: brightness(0.95);
        }

        footer.footer {
            background-color: #23272b;
            padding: 1rem 0;
            font-size: 0.9rem;
            text-align: center;
            color: #bdbdbd;
            border-top: 2px solid #ff9800;
        }

        .login-container {
            margin-top: 40px;
            background-color: #2c3035;
            border-radius: 10px;
            padding: 28px 24px;
            box-shadow: 0 6px 18px rgba(255, 152, 0, 0.10);
            font-size: 1rem;
            color: #f5f5f5;
            max-width: 400px;
        }

        .form-control {
            border-radius: 4px;
            font-size: 1rem;
            background-color: #23272b;
            color: #f5f5f5;
            border: 1px solid #ff9800;
        }

            .form-control:focus {
                border-color: #ffa733;
                box-shadow: 0 0 0 0.2rem rgba(255, 152, 0, 0.15);
                background-color: #23272b;
                color: #fff;
            }

        .btn-primary {
            background-color: #ff9800;
            border: none;
            border-radius: 4px;
            padding: 10px;
            width: 100%;
            font-size: 1.05rem;
            color: #23272b;
            font-weight: 600;
            letter-spacing: 0.5px;
            transition: background 0.2s;
        }

            .btn-primary:hover {
                background-color: #ffa733;
                color: #23272b;
            }

        /* Links padrão */
        a, a:visited {
            color: #ff9800;
            text-decoration: none;
        }

            a:hover, a:focus {
                color: #ffa733;
                text-decoration: underline;
            }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark border-bottom">
            <div class="container d-flex align-items-center justify-content-between">
                <a class="navbar-brand" asp-area="" asp-page="/Login">
                    <img src="~/logo3.png" alt="Logo" />
                </a>
                <div class="d-flex gap-2">
                    @* Botões de menu desativados no login *@
                </div>
            </div>
        </nav>
    </header>

    <div class="container d-flex justify-content-center align-items-center" style="min-height: 80vh;">
        <main role="main" class="pb-3 login-container">
            @RenderBody()
        </main>
    </div>

    <footer class="footer">
        <div class="container">
            &copy; @DateTime.Now.Year - VUC Locadora
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>